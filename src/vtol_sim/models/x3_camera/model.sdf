<sdf version="1.6">
  <model name="x3">
    <pose>0 0 0.053302 0 0 0</pose>

    <!-- ===== Body ===== -->
    <link name="X3/base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>1.5</mass>
        <inertia>
          <ixx>0.0347563</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.07</iyy><iyz>0</iyz>
          <izz>0.0977</izz>
        </inertia>
      </inertial>
      <collision name="X3/base_link_inertia_collision">
        <geometry>
          <box><size>0.47 0.47 0.11</size></box>
        </geometry>
      </collision>
      <visual name="X3/base_link_inertia_visual">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/x3 uav/4/files/meshes/x3.dae</uri>
          </mesh>
        </geometry>
      </visual>

      <!-- Forward-facing camera, 10 cm in front of body centre -->
      <sensor name="front_camera" type="camera">
        <pose>0.1 0 0 0 0 0</pose>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>X3/camera/image_raw</topic>
      </sensor>
    </link>

    <!-- ===== Rotors ===== -->
    <link name="X3/rotor_0">
      <pose>0.13 -0.22 0.023 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>9.75e-07</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>4.17041e-05</iyy><iyz>0</iyz>
          <izz>4.26041e-05</izz>
        </inertia>
      </inertial>
      <collision name="X3/rotor_0_collision">
        <geometry><cylinder><length>0.005</length><radius>0.1</radius></cylinder></geometry>
      </collision>
      <visual name="X3/rotor_0_visual">
        <geometry>
          <mesh>
            <scale>0.1 0.1 0.1</scale>
            <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/x3 uav/4/files/meshes/propeller_ccw.dae</uri>
          </mesh>
        </geometry>
        <material><script><name>Gazebo/Blue</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>
      <gravity>1</gravity>
    </link>
    <joint name="X3/rotor_0_joint" type="revolute">
      <child>X3/rotor_0</child>
      <parent>X3/base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <link name="X3/rotor_1">
      <pose>-0.13 0.2 0.023 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>9.75e-07</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>4.17041e-05</iyy><iyz>0</iyz>
          <izz>4.26041e-05</izz>
        </inertia>
      </inertial>
      <collision name="X3/rotor_1_collision">
        <geometry><cylinder><length>0.005</length><radius>0.1</radius></cylinder></geometry>
      </collision>
      <visual name="X3/rotor_1_visual">
        <geometry>
          <mesh>
            <scale>0.1 0.1 0.1</scale>
            <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/x3 uav/4/files/meshes/propeller_ccw.dae</uri>
          </mesh>
        </geometry>
        <material><script><name>Gazebo/Red</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>
      <gravity>1</gravity>
    </link>
    <joint name="X3/rotor_1_joint" type="revolute">
      <child>X3/rotor_1</child>
      <parent>X3/base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <link name="X3/rotor_2">
      <pose>0.13 0.22 0.023 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>9.75e-07</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>4.17041e-05</iyy><iyz>0</iyz>
          <izz>4.26041e-05</izz>
        </inertia>
      </inertial>
      <collision name="X3/rotor_2_collision">
        <geometry><cylinder><length>0.005</length><radius>0.1</radius></cylinder></geometry>
      </collision>
      <visual name="X3/rotor_2_visual">
        <geometry>
          <mesh>
            <scale>0.1 0.1 0.1</scale>
            <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/x3 uav/4/files/meshes/propeller_cw.dae</uri>
          </mesh>
        </geometry>
        <material><script><name>Gazebo/Blue</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>
      <gravity>1</gravity>
    </link>
    <joint name="X3/rotor_2_joint" type="revolute">
      <child>X3/rotor_2</child>
      <parent>X3/base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <link name="X3/rotor_3">
      <pose>-0.13 -0.2 0.023 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>9.75e-07</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>4.17041e-05</iyy><iyz>0</iyz>
          <izz>4.26041e-05</izz>
        </inertia>
      </inertial>
      <collision name="X3/rotor_3_collision">
        <geometry><cylinder><length>0.005</length><radius>0.1</radius></cylinder></geometry>
      </collision>
      <visual name="X3/rotor_3_visual">
        <geometry>
          <mesh>
            <scale>0.1 0.1 0.1</scale>
            <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/x3 uav/4/files/meshes/propeller_cw.dae</uri>
          </mesh>
        </geometry>
        <material><script><name>Gazebo/Red</name><uri>file://media/materials/scripts/gazebo.material</uri></script></material>
      </visual>
      <gravity>1</gravity>
    </link>
    <joint name="X3/rotor_3_joint" type="revolute">
      <child>X3/rotor_3</child>
      <parent>X3/base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

  </model>
</sdf>
